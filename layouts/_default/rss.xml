{{- $pages := .RegularPages -}}
{{- if .IsHome -}}
  {{- $pages = where site.RegularPages "Section" "posts" -}}
{{- else if .IsSection -}}
  {{- $pages = .RegularPagesRecursive -}}
{{- end -}}
{{- $limit := site.Config.Services.RSS.Limit -}}
{{- if ge $limit 1 -}}
  {{- $pages = first $limit $pages -}}
{{- end -}}
{{- $title := site.Title -}}
{{- if not .IsHome -}}
  {{- $title = printf "%s on %s" .Title site.Title -}}
{{- end -}}
{{- $description := printf "Recent content on %s" site.Title -}}
{{- if not .IsHome -}}
  {{- $description = printf "Recent content in %s on %s" .Title site.Title -}}
{{- end -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ $title }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ $description }}</description>
    <generator>Hugo {{ hugo.Version }}</generator>
    <language>{{ site.Language.Lang }}</language>
    {{ with .OutputFormats.Get "RSS" }}
      <atom:link href="{{ .Permalink }}" rel="self" type="application/rss+xml" />
    {{ end }}
    {{ range $pages }}
      <item>
        <title>{{ .Title }}</title>
        <link>{{ .Permalink }}</link>
        {{ if not .PublishDate.IsZero }}
          <pubDate>{{ .PublishDate.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
        {{ else if not .Date.IsZero }}
          <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
        {{ end }}
        <guid>{{ .Permalink }}</guid>
        <description>{{ .Summary | html }}</description>
      </item>
    {{ end }}
  </channel>
</rss>
